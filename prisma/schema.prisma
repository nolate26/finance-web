generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}
// ==========================================
// SECCIÓN: SEGURIDAD Y USUARIOS (NextAuth)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?   // ¡Añadido para login tradicional!
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}


// ==========================================
// SECCIÓN: FONDOS Y UNIVERSO
// ==========================================

model FundPortfolioWeight {
  fundName        String   @map("fund_name") @db.VarChar(100)
  reportDate      DateTime @map("report_date") @db.Date
  company         String   @db.VarChar(200)
  portfolioWeight Float?   @map("portfolio_weight")
  benchmarkName   String?  @map("benchmark_name") @db.VarChar(100)
  benchmarkWeight Float?   @map("benchmark_weight")
  overweight      Float?

  @@id([fundName, reportDate, company])
  @@map("fund_portfolio_weights")
}

model PerformanceAttribution {
  reportDate     DateTime @map("report_date") @db.Date
  fund           String   @db.VarChar(200)
  security       String   @db.VarChar(200)
  sourceFile     String?  @map("source_file") @db.VarChar(255)
  benchmark      String?  @db.VarChar(200)
  fundAvgWeight  Float?   @map("fund_avg_weight")
  fundContrib    Float?   @map("fund_contrib")
  benchAvgWeight Float?   @map("bench_avg_weight")
  benchContrib   Float?   @map("bench_contrib")
  selectEffect   Float?   @map("select_effect")
  allocEffect    Float?   @map("alloc_effect")
  totalEffect    Float?   @map("total_effect")
  rowType        String?  @map("row_type") @db.VarChar(50)

  @@id([reportDate, fund, security])
  @@map("performance_attribution")
}
model top_picks {
  id                 String   @id @default(cuid())
  region             String   // Guardará "LATAM" o "CHILE"
  period_date        DateTime // Guardará el mes (ej: 2026-04-01)
  
  // La conexión con tu tabla maestra usando el Nombre (Llave Primaria)
  nombre_latam       String   
  empresa            EmpresasIndustrias @relation(fields: [nombre_latam], references: [nombreLatam])

  // Los datos del reporte
  industry_group     String
  comment            String   @db.Text
  target_price       Float?   // Opcional
  
  created_at         DateTime @default(now())

  // Esto evita que alguien ingrese la misma empresa dos veces en el mismo reporte
  @@unique([region, period_date, nombre_latam])
}


// ─── Tabla 7: Total Return Index con dividendos brutos ───────────────────
model TotalReturnIndex {
  id Int @id @default(autoincrement())
  ticker String
  date DateTime @db.Date
  triToday Float? @map("tri_today")
  tri1m Float? @map("tri_1m")
  tri3m Float? @map("tri_3m")
  tri6m Float? @map("tri_6m")
  tri1y Float? @map("tri_1y")
  tri2y Float? @map("tri_2y")
 
  @@unique([ticker, date])
  @@index([ticker])
  @@map("total_return_index")
}

model EmpresasIndustrias {
  nombreLatam     String  @id @map("nombre_latam") @db.VarChar(200)
  nombreChile     String? @map("nombre_chile") @db.VarChar(200)
  industriaGics   String? @map("industria_gics") @db.VarChar(200)
  industriaChile  String? @map("industria_chile") @db.VarChar(200)
  tickerBloomberg String? @map("ticker_bloomberg") @db.VarChar(100)
  companyDescription String? @map("company_description") @db.Text
  top_picks           top_picks[]
  @@map("empresas_industrias")
}
model SsUniverse {
  cierreCartera  DateTime @map("cierre_cartera") @db.Date
  recordType     String   @map("record_type") @db.VarChar(10)
  company        String   @db.VarChar(200)
  sourceFile     String?  @map("source_file") @db.VarChar(255)
  precios        String?  @db.VarChar(30)
  resultados     String?  @db.VarChar(30)

  mrvVsIpsa      String?  @map("mrv_vs_ipsa") @db.VarChar(50)
  price          Float?
  ret1m          Float?   @map("ret_1m")
  retYtd         Float?   @map("ret_ytd")
  ret1y          Float?   @map("ret_1y")
  ret5y          Float?   @map("ret_5y")
  mktCapBn       Float?   @map("mkt_cap_bn")
  netDebt        Float?   @map("net_debt")
  fv             Float?

  ebitdaPrev     Float?   @map("ebitda_prev")
  ebitdaAct      Float?   @map("ebitda_act")
  ebitdaChg      Float?   @map("ebitda_chg")

  netIncomePrev  Float?   @map("net_income_prev")
  netIncomeAct   Float?   @map("net_income_act")
  netIncomeChg   Float?   @map("net_income_chg")

  ebitdaLtm      Float?   @map("ebitda_ltm")
  ebitdaYr1e     Float?   @map("ebitda_yr1e")
  ebitdaYr2e     Float?   @map("ebitda_yr2e")

  fvEbitdaLtm    Float?   @map("fv_ebitda_ltm")
  fvEbitdaYr1e   Float?   @map("fv_ebitda_yr1e")
  fvEbitdaYr2e   Float?   @map("fv_ebitda_yr2e")

  niLtm          Float?   @map("ni_ltm")
  niYr1e         Float?   @map("ni_yr1e")
  niYr2e         Float?   @map("ni_yr2e")

  peLtm          Float?   @map("pe_ltm")
  peYr1e         Float?   @map("pe_yr1e")
  peYr2e         Float?   @map("pe_yr2e")

  pCeLtm         Float?   @map("p_ce_ltm")
  pBvLtm         Float?   @map("p_bv_ltm")
  roeLtm         Float?   @map("roe_ltm")
  roeYr1e        Float?   @map("roe_yr1e")
  fvSLtm         Float?   @map("fv_s_ltm")
  
  poolDiv        String?  @map("pool_div") @db.VarChar(100)
  divYield       Float?   @map("div_yield")
  roicLtm        Float?   @map("roic_ltm")
  fvIc           Float?   @map("fv_ic")
  recommendation String?  @db.VarChar(50)

  targetPrice    Float?   @map("target_price")

  @@id([cierreCartera, recordType, company])
  @@map("ss_universe")
}

model MonedaFundReturn {
  reportDate    String  @map("report_date") @db.VarChar(30)
  currency      String  @db.VarChar(10)
  fund          String  @db.VarChar(255)
  sourceFile    String? @map("source_file") @db.VarChar(255)
  pageNum       Int?    @map("page_num") @db.SmallInt
  fundGroup     String? @map("fund_group") @db.VarChar(100)
  inceptionDate String? @map("inception_date") @db.VarChar(30)
  manager       String? @db.VarChar(100)
  mgmtFee       String? @map("mgmt_fee") @db.VarChar(100)
  nav           Float?
  aumUsdMm      Float?  @map("aum_usd_mm")
  incep         Float?
  mtd           Float?
  ytd           Float?
  ret1y         Float?  @map("ret_1y")
  ret3y         Float?  @map("ret_3y")
  ret5y         Float?  @map("ret_5y")
  ret10y        Float?  @map("ret_10y")
  dyn1Label     String? @map("dyn_1_label") @db.VarChar(80)
  dyn1          Float?  @map("dyn_1")
  dyn2Label     String? @map("dyn_2_label") @db.VarChar(80)
  dyn2          Float?  @map("dyn_2")
  dyn3Label     String? @map("dyn_3_label") @db.VarChar(80)
  dyn3          Float?  @map("dyn_3")
  sigma         Float?
  sharpe        Float?
  alpha         Float?
  beta          Float?

  @@id([reportDate, currency, fund])
  @@map("moneda_fund_returns")
}

model proyecciones_financieras {
  generated_at  DateTime @db.Timestamp(6)
  empresa       String   @db.VarChar(200)
  source_file   String?  @db.VarChar(255)
  moneda        String?  @db.VarChar(20)
  analyst       String?  @db.VarChar(100)
  div           String?  @db.VarChar(100)
  base_year     Int      @default(2025)
  ingresos_y0   Float?
  ebitda_y0     Float?
  utilidad_y0   Float?
  ebit_y0       Float?
  ingresos_y1   Float?
  ebitda_y1     Float?
  utilidad_y1   Float?
  ebit_y1       Float?
  ingresos_y2   Float?
  ebitda_y2     Float?
  utilidad_y2   Float?
  ebit_y2       Float?

  @@id([generated_at, empresa])
}

model LatamEquitySnapshot {
  id            Int      @id @default(autoincrement())
  snapshotDate  DateTime @default(now())
  ticker        String
  priceUsdTri   Float?   
  ret1W         Float?
  ret1M         Float?
  retYtd        Float?
  ret1Y         Float?
  ret5Y         Float?
  priceUsd      Float?   
  mktCapUsd     Float?   
  netDebtUsd    Float?   
  evUsd         Float?   
  peCurYr       Float?   
  peNxtYr       Float?   
  evEbitdaCurYr Float?   
  evEbitdaNxtYr Float?   
  evSalesCurYr  Float?   
  evSalesNxtYr  Float?   
  pBv           Float?   
  leverage      Float?   
  roeEst        Float?   
  divYield      Float?   
  priceLocal    Float?   
  targetPrice   Float?   
  tpUpside      Float?   
  niRealQ1      Float?
  niRealQ2      Float?
  niRealQ3      Float?
  niRealQ4      Float?
  niEstQ1       Float?
  niEstQ2       Float?
  niEstQ3       Float?
  niEstQ4       Float?
  niYoyQ1       Float?
  niYoyQ2       Float?
  niYoyQ3       Float?
  niYoyQ4       Float?
  epsEst        Float?   
  epsRev1W      Float?   
  epsRev4W      Float?   
  epsRev3M      Float?   

  @@index([snapshotDate])
  @@index([ticker])
  @@map("latam_equity_snapshots")
}

// ==========================================
// SECCIÓN ECONOMÍA Y MERCADO
// ==========================================

model MacroHistorico {
  date      DateTime
  pais      String
  indicador String
  valor     Float?

  @@id([date, pais, indicador])
  @@index([pais, indicador])
}

model PeHistorico {
  date    DateTime
  indice  String
  peValue Float?

  @@id([date, indice])
}

model CommodityHistorico {
  date      DateTime
  commodity String
  precio    Float?

  @@id([date, commodity])
}

model MacroForecasts {
  id           Int      @id @default(autoincrement())
  snapshotDate DateTime @default(now())
  country      String
  indicator    String
  prev_3mAgo   String?
  current_Y0   String?
  current_Y1   String?
  current_Y2   String?

  @@index([snapshotDate])
}

model CommodityForecasts {
  id              Int      @id @default(autoincrement())
  snapshotDate    DateTime @default(now())
  commodity       String
  quarter         String
  spotCurrent     Float?
  fwdCurve        String?
  analystForecast String?

  @@index([snapshotDate])
}

model PeSummarySnapshot {
  id           Int      @id @default(autoincrement())
  snapshotDate DateTime @default(now())
  index        String
  todayPE      Float?
  histAvg      Float?
  plus1Std     Float?
  minus1Std    Float?
  discount     String?

  @@index([snapshotDate])
}

model EquityCompsSnapshot {
  id            Int      @id @default(autoincrement())
  snapshotDate  DateTime @default(now())
  ticker        String
  indexName     String
  priceLocal    Float?
  ret1W         String?
  ret1M         String?
  ret3M         String?
  retYTD        String?
  ret1Y         String?
  ret3Y         String?
  ret5Y         String?
  ret10Y        String?
  evEbitdaFwd   Float?
  peFwd         Float?
  evEbitdaTrail Float?
  roeTrail      Float?
  peTrail       Float?

  @@index([snapshotDate])
}

// ==========================================
// SECCIÓN: COMPANY DEEP DIVE (NUEVAS TABLAS)
// ==========================================

// ─── Tabla 1: Valuación histórica (SERIE MENSUAL, 10Y) ────────────────────
model ValuationHistory {
  id          Int      @id @default(autoincrement())
  ticker      String
  date        DateTime @db.Date
  peFwd       Float?
  evEbitdaFwd Float?
  pbv         Float?
  roeFwd      Float?

  @@unique([ticker, date])
  @@index([ticker])
  @@index([date])
  @@map("valuation_history")
}

// ─── Tabla 2: Consenso de estimaciones (SERIE mensual) ───────────────────
model ConsensusEstimate {
  id      Int      @id @default(autoincrement())
  ticker  String
  date    DateTime @db.Date
  metric  String
  period  String   // AHORA: '1FY' o '2FY' (antes '2026Y')
  value   Float

  @@unique([ticker, date, metric, period])
  @@index([ticker])
  @@index([ticker, metric])
  @@index([period]) // NUEVO: para filtrar rápido 1FY vs 2FY
  @@map("consensus_estimates")
}

// ─── Tabla 3: Precio vs Net Income (SERIE MENSUAL 5Y, solo 1BF blended) ────────────────────────
model PriceVsEarnings {
  id      Int      @id @default(autoincrement())
  ticker  String
  date    DateTime @db.Date
  pxLast  Float
  ni1bf   Float?   // NUEVO: Net Income blended 12m

  @@unique([ticker, date])
  @@index([ticker])
  @@index([date])
  @@map("price_vs_earnings")
}

// ─── Tabla 4: Short Interest (FOTO acumulada) ────────────────────────────
model ShortInterest {
  id            Int      @id @default(autoincrement())
  ticker        String
  date          DateTime @db.Date
  shortIntRatio Float

  @@unique([ticker, date])
  @@index([ticker])
  @@map("short_interest")
}

// ─── Tabla 5: Rango 52 semanas (FOTO acumulada) ─────────────────────────
model PriceRange52w {
  id       Int      @id @default(autoincrement())
  ticker   String
  date     DateTime @db.Date
  pxLast   Float
  high52w  Float
  low52w   Float
  pctRange Float?

  @@unique([ticker, date])
  @@index([ticker])
  @@map("price_range_52w")
}

// ─── Tabla 6: Recomendaciones de analistas (FOTO acumulada) ──────────────
model AnalystRecommendation {
  id          Int      @id @default(autoincrement())
  ticker      String
  date        DateTime @db.Date
  totAnalysts Int
  buy         Int      @default(0)
  hold        Int      @default(0)
  sell        Int      @default(0)
  consenso    String?
  targetPrice Float?   // <--- NUEVO CAMPO AGREGADO

  @@unique([ticker, date])
  @@index([ticker])
  @@map("analyst_recommendations")
}
// ─── Tracking de corridas incrementales ──────────────────────────────────
model LastRun {
  id       Int    @id @default(autoincrement())
  ticker   String
  module   String
  lastDate String

  @@unique([ticker, module])
  @@map("last_run")
}